# ╔══════════════════════════════════════════════════════════╗
# ║         İştek Platform — Ortam Değişkenleri             ║
# ║  Bu dosyayı .env olarak kaydedin, asla git'e eklemeyin  ║
# ╚══════════════════════════════════════════════════════════╝

# ── Uygulama ──────────────────────────────────────────────
# Güçlü rastgele bir değer üretin: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=buraya-guclu-rastgele-bir-deger-girin-degistirin

# Debug modu: canlıda 0, geliştirmede 1
FLASK_DEBUG=0

# ── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=mysql-sifreniz
DB_NAME=istek_db

# ── E-posta (Gmail SMTP) ──────────────────────────────────
# Gmail → Güvenlik → 2FA → Uygulama Şifreleri
MAIL_USERNAME=istek.platform@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Netgsm SMS ────────────────────────────────────────────
NETGSM_KULLANICI=850XXXXXXX
NETGSM_SIFRE=netgsm-sifreniz
NETGSM_BASLIK=ISTEK

# ── iyzico Ödeme ──────────────────────────────────────────
# Sandbox: https://sandbox-api.iyzipay.com
# Canlı:   https://api.iyzipay.com
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── Google OAuth ──────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Güvenlik ──────────────────────────────────────────────
# Rate limiting için Redis (opsiyonel, yoksa bellek kullanılır)
# REDIS_URL=redis://localhost:6379/0
